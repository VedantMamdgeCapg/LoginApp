@model LoginApp.Models.ApplicationUser
@{ ViewData["Title"] = "Dashboard"; }

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-5 text-center">
                    <h2 class="card-title mb-3">Welcome, @Model?.FullName!</h2>
                    <p class="text-muted mb-4">You are signed in.</p>

                    <div class="mb-4">
                        <p class="mb-1"><strong>Email</strong></p>
                        <p class="text-muted">@Model?.Email</p>
                    </div>

                    <div class="d-flex justify-content-center flex-wrap gap-2">
                        <a class="btn btn-outline-primary" asp-action="ChangePassword">Change Password</a>
                        <a class="btn btn-outline-secondary" asp-action="ChangeUsername">Change Username</a>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger">Logout</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
