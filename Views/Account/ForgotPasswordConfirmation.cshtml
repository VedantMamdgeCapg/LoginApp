@{
    ViewData["Title"] = "Password Reset Requested";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body p-4 text-center">
                <h3 class="mb-3">Password reset requested</h3>
                <p class="text-muted">If the email exists, you can now reset your password using the link provided.</p>
                <a class="btn btn-primary mt-3" asp-action="Login">Back to Login</a>
            </div>
        </div>
    </div>
</div>
