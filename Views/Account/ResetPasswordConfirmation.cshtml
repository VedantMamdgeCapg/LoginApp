@{
    ViewData["Title"] = "Password Reset Complete";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body p-4 text-center">
                <h3 class="mb-3">Password reset complete</h3>
                <p class="text-muted">Your password has been updated successfully. You can now sign in with your new password.</p>
                <a class="btn btn-primary mt-3" asp-action="Login">Go to Login</a>
            </div>
        </div>
    </div>
</div>
